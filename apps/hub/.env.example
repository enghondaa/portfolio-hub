# Email delivery for the contact form (apps/hub/src/app/api/contact/route.ts).
# Uses Resend (https://resend.com), free tier. Leave unset and the API route
# will respond with a friendly "not configured yet" message, and the contact
# page falls back to a mailto: link so the form never dead-ends.
RESEND_API_KEY=
# Address the contact form should deliver to. Falls back to a hardcoded
# address in the route if unset.
CONTACT_TO_EMAIL=
